# 使用方式（任选其一）：
# 1) 复制本文件为同目录下的 app.env，填写下面一行密钥（app.env 已在 .gitignore，勿提交）。
# 2) 运行：flutter run -d chrome --dart-define=REMOVE_BG_API_KEY=你的密钥
# 3) Cursor/VS Code：在 launch.json 的 toolArgs 里加上上述 --dart-define
#
# 密钥在 https://www.remove.bg/api 注册后获取。
REMOVE_BG_API_KEY=

# Supabase（云端衣物/搭配/图片）：https://supabase.com 创建项目后，在 Settings → API 复制
# 在 SQL Editor 执行 supabase/migrations/001_wardrobe_cloud.sql；Storage 创建 bucket「wardrobe」并设为 public
# Authentication → Providers 启用 Email（邮箱+密码）；开发可在 Auth 设置里关闭「Confirm email」以便立即登录
#SUPABASE_URL=https://xxxx.supabase.co
#SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=
SUPABASE_ANON_KEY=

# AI 搭配推荐（OpenAI 兼容接口，如 https://api.openai.com/v1）
# 密钥仅放在本地 app.env，勿提交；Web 端直连存在密钥暴露风险，生产环境建议经后端代理。
#AI_API_KEY=sk-...
#AI_API_BASE_URL=https://api.openai.com/v1
#AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_API_BASE_URL=
